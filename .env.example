FLASK_ENV=production
SECRET_KEY=change-me
DATABASE_URL=sqlite:///instance/dons.db

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@dons-cafe.de

STORE_NOTIFICATION_EMAIL=orders@dons-cafe.de
PUBLIC_CONTACT_EMAIL=kontakt@dons-cafe.de
ADMIN_PASSWORD=change-me

MIN_ORDER_AMOUNT=50
LEAD_TIME_HOURS=48

# LLM Chatbot (Ollama) — running on the host machine
# IMPORTANT: always use host.docker.internal — never a hardcoded LAN IP.
# docker-compose.yml maps host.docker.internal → host-gateway so it works on Linux too.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi4-mini:latest
