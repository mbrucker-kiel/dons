FLASK_ENV=production
SECRET_KEY=change-me
DATABASE_URL=sqlite:///instance/dons.db

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@dons-cafe.de

STORE_NOTIFICATION_EMAIL=orders@dons-cafe.de
PUBLIC_CONTACT_EMAIL=kontakt@dons-cafe.de
ADMIN_PASSWORD=change-me

MIN_ORDER_AMOUNT=50
LEAD_TIME_HOURS=48

# LLM Chatbot (Ollama)
#
# Scenario A — Ollama runs on a DIFFERENT machine on the LAN (recommended setup):
#   Use the machine's direct IP or hostname; Docker can reach it natively.
#   Example: OLLAMA_BASE_URL=http://192.168.178.41:11434
#
# Scenario B — Ollama runs on the SAME machine as Docker:
#   Use host.docker.internal (mapped to the Docker host via extra_hosts in docker-compose.yml).
#   Example: OLLAMA_BASE_URL=http://host.docker.internal:11434
#
OLLAMA_BASE_URL=http://192.168.178.41:11434
OLLAMA_MODEL=phi4-mini:latest
